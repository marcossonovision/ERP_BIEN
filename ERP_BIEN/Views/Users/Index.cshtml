@model List<ERP_BIEN.Models.ViewModels.UserViewModel>

@Html.AntiForgeryToken()

<pre style="background:#111;color:#0f0;padding:10px">
    MODULES:
    @string.Join(", ", User.Claims.Where(c => c.Type == "module").Select(c => c.Value))

    PERMISSIONS:
    @string.Join(", ", User.Claims.Where(c => c.Type == "permission").Select(c => c.Value))
</pre>

<h2 class="mb-4">Gestión de Usuarios</h2>

<style>
    .user-row button {
        pointer-events: auto !important;
        position: relative;
        z-index: 10;
    }

    .user-row {
        position: relative;
        z-index: 1;
        cursor: pointer;
    }

    .pagination .page-link {
        pointer-events: auto !important;
    }
</style>

<!-- ========================= -->
<!-- FILTROS + CREAR USUARIO -->
<!-- ========================= -->
<form method="get" asp-action="Index" asp-controller="Users" class="card card-body mb-4" id="usersFiltersForm">
    <div class="row g-3 align-items-end">
        <input type="hidden" name="pageNumber" value="1" />

        <div class="col-md-3">
            <label class="form-label">Nombre</label>
            <input name="searchName" value="@ViewBag.SearchName" class="form-control" placeholder="Buscar por nombre..." />
        </div>

        <div class="col-md-3">
            <label class="form-label">Usuario</label>
            <input name="searchDomain" value="@ViewBag.SearchDomain" class="form-control" placeholder="Buscar por usuario..." />
        </div>

        <div class="col-md-3">
            <label class="form-label">Equipo</label>
            <select name="searchTeamId" class="form-control" id="searchTeamId">
                <option value="">Todos</option>
                @foreach (var t in ViewBag.TeamList)
                {
                    if (ViewBag.SearchTeamId?.ToString() == t.Value)
                    {
                        <option value="@t.Value" selected>@t.Text</option>
                    }
                    else
                    {
                        <option value="@t.Value">@t.Text</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-3 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-primary">
                Filtrar
            </button>

            <button type="button"
                    id="clearFiltersBtn"
                    class="btn btn-outline-secondary">
                Limpiar filtros
            </button>

            <a asp-action="ExportExcel"
                   asp-controller="Users"
                   class="btn btn-success">
                📊 Excel
            </a>
        </div>

        <div class="col-12 d-flex justify-content-end mt-2">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
                + Crear Usuario
            </button>
        </div>
    </div>
</form>

<!-- ========================= -->
<!-- TABLA -->
<!-- ========================= -->
<table class="table table-hover">
    <thead class="table-light">
        <tr>
            <th>Nombre</th>
            <th>Usuario</th>
            <th>Equipo</th>
            <th style="width:150px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr class="user-row" data-id="@u.Id">
                <td>@u.Name @u.LastName</td>
                <td>@u.DomainUser</td>
                <td>@u.TeamName</td>
                <td>
                    <button type="button" class="btn btn-sm btn-warning edit-btn" data-id="@u.Id">Editar</button>
                    <button type="button" class="btn btn-sm btn-danger delete-btn" data-id="@u.Id">Eliminar</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">No se encontraron usuarios.</p>
}

<!-- ========================= -->
<!-- PAGINACIÓN -->
<!-- ========================= -->
<nav aria-label="Paginación">
    <ul class="pagination justify-content-center">
        <li class="page-item @(((int)ViewBag.PageNumber) == 1 ? "disabled" : "")">
            @if (((int)ViewBag.PageNumber) > 1)
            {
                <a class="page-link"
                       href="@Url.Action("Index", new { pageNumber = (int)ViewBag.PageNumber - 1, searchName = ViewBag.SearchName, searchDomain = ViewBag.SearchDomain, searchTeamId = ViewBag.SearchTeamId })">
                    Anterior
                </a>
            }
            else
            {
                <span class="page-link">Anterior</span>
            }
        </li>

        @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
        {
            var active = i == (int)ViewBag.PageNumber ? "active" : "";
            <li class="page-item @active">
                @if (i == (int)ViewBag.PageNumber)
                {
                    <span class="page-link">@i</span>
                }
                else
                {
                    <a class="page-link"
                           href="@Url.Action("Index", new { pageNumber = i, searchName = ViewBag.SearchName, searchDomain = ViewBag.SearchDomain, searchTeamId = ViewBag.SearchTeamId })">
                        @i
                    </a>
                }
            </li>
        }

        <li class="page-item @(((int)ViewBag.PageNumber) == (int)ViewBag.TotalPages || ((int)ViewBag.TotalPages) == 0 ? "disabled" : "")">
            @if (((int)ViewBag.TotalPages) > 0 && ((int)ViewBag.PageNumber) < (int)ViewBag.TotalPages)
            {
                <a class="page-link"
                       href="@Url.Action("Index", new { pageNumber = (int)ViewBag.PageNumber + 1, searchName = ViewBag.SearchName, searchDomain = ViewBag.SearchDomain, searchTeamId = ViewBag.SearchTeamId })">
                    Siguiente
                </a>
            }
            else
            {
                <span class="page-link">Siguiente</span>
            }
        </li>
    </ul>
</nav>

<!-- ========================= -->
<!-- MODAL: CREAR USUARIO -->
<!-- ========================= -->
<div class="modal fade" id="createModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-action="Create" asp-controller="Users">
                @Html.AntiForgeryToken()

                <input type="hidden" name="pageNumber" value="@ViewBag.PageNumber" />
                <input type="hidden" name="searchName" value="@ViewBag.SearchName" />
                <input type="hidden" name="searchDomain" value="@ViewBag.SearchDomain" />
                <input type="hidden" name="searchTeamId" value="@ViewBag.SearchTeamId" />

                <div class="modal-header">
                    <h5 class="modal-title">Crear Usuario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <label>Nombre</label>
                    <input name="Name" class="form-control" required />

                    <label class="mt-3">Apellidos</label>
                    <input name="LastName" class="form-control" required />

                    <label class="mt-3">Usuario de Dominio</label>
                    <input name="DomainUser" class="form-control" required />

                    <label class="mt-3">Equipo</label>
                    <select name="TeamId" class="form-control">
                        <option value="">-- Sin equipo --</option>
                        @foreach (var t in ViewBag.TeamList)
                        {
                            <option value="@t.Value">@t.Text</option>
                        }
                    </select>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Crear</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ========================= -->
<!-- MODAL: DETALLES -->
<!-- ========================= -->
<div class="modal fade" id="detailsModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Detalles del Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p><strong>Nombre:</strong> <span id="det-name"></span></p>
                <p><strong>Usuario:</strong> <span id="det-domain"></span></p>
                <p><strong>Equipo:</strong> <span id="det-team"></span></p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-warning" id="openEditFromDetails">Editar</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- ========================= -->
<!-- MODAL: EDITAR -->
<!-- ========================= -->
<div class="modal fade" id="editModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-action="Edit" asp-controller="Users">
                @Html.AntiForgeryToken()

                <input type="hidden" name="Id" id="edit-id" />
                <input type="hidden" name="pageNumber" value="@ViewBag.PageNumber" />
                <input type="hidden" name="searchName" value="@ViewBag.SearchName" />
                <input type="hidden" name="searchDomain" value="@ViewBag.SearchDomain" />
                <input type="hidden" name="searchTeamId" value="@ViewBag.SearchTeamId" />

                <div class="modal-header">
                    <h5 class="modal-title">Editar Usuario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <label>Nombre</label>
                    <input name="Name" id="edit-name" class="form-control" />

                    <label class="mt-3">Apellidos</label>
                    <input name="LastName" id="edit-lastname" class="form-control" />

                    <label class="mt-3">Usuario de Dominio</label>
                    <input name="DomainUser" id="edit-domain" class="form-control" />

                    <label class="mt-3">Equipo</label>
                    <select name="TeamId" id="edit-team" class="form-control">
                        @foreach (var t in ViewBag.TeamList)
                        {
                            <option value="@t.Value">@t.Text</option>
                        }
                    </select>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ========================= -->
<!-- MODAL: CONFIRMAR ELIMINACIÓN -->
<!-- ========================= -->
<div class="modal fade" id="deleteModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Eliminar Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>¿Seguro que deseas eliminar este usuario?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancelar
                </button>
                <button type="button" id="confirmDeleteBtn" class="btn btn-danger">
                    Eliminar
                </button>
            </div>

        </div>
    </div>
</div>

<!-- ========================= -->
<!-- MODAL: ELIMINADO CORRECTAMENTE -->
<!-- ========================= -->
<div class="modal fade"
     id="deleteSuccessModal"
     data-bs-backdrop="static"
     data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Usuario eliminado</h5>
            </div>

            <div class="modal-body">
                <p>El usuario se ha eliminado correctamente.</p>
            </div>

            <div class="modal-footer">
                <button type="button" id="closeSuccessBtn" class="btn btn-primary">
                    Aceptar
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {

            console.log("Scripts de Usuarios cargados");

            // =========================
            // CLICK EN FILA → VER DETALLES
            // =========================
            document.querySelectorAll(".user-row").forEach(row => {
                row.addEventListener("click", async (e) => {
                    if (e.target.closest("button") || e.target.closest("[data-bs-toggle]")) return;
                    const id = row.dataset.id;
                    if (!id) return;
                    await loadDetails(id);
                });
            });

            // =========================
            // EDITAR
            // =========================
            document.querySelectorAll(".edit-btn").forEach(btn => {
                btn.addEventListener("click", async (e) => {
                    e.stopPropagation();
                    const id = btn.dataset.id;
                    if (!id) return;

                    try {
                        const res = await fetch(`/Users/Details/${id}`);
                        if (!res.ok) throw new Error('Error fetching details');
                        const u = await res.json();

                        document.getElementById("edit-id").value = u.id ?? '';
                        document.getElementById("edit-name").value = u.name ?? '';
                        document.getElementById("edit-lastname").value = u.lastName ?? '';
                        document.getElementById("edit-domain").value = u.domainUser ?? '';
                        document.getElementById("edit-team").value = u.teamId ?? '';

                        new bootstrap.Modal(document.getElementById("editModal")).show();
                    } catch (err) {
                        console.error('Error al cargar datos para editar:', err);
                    }
                });
            });

            // =========================
            // ELIMINAR (AJAX + MODALES)
            // =========================
            let userIdToDelete = null;

            document.querySelectorAll(".delete-btn").forEach(btn => {
                btn.addEventListener("click", (e) => {
                    e.stopPropagation();
                    userIdToDelete = btn.dataset.id;
                    new bootstrap.Modal(document.getElementById("deleteModal")).show();
                });
            });

            const confirmDeleteBtn = document.getElementById("confirmDeleteBtn");
            if (confirmDeleteBtn) {
                confirmDeleteBtn.addEventListener("click", async () => {
                    if (!userIdToDelete) return;

                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                    const response = await fetch('/Users/Delete', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({ id: userIdToDelete })
                    });

                    if (response.ok) {
                        const deleteModalInstance = bootstrap.Modal.getInstance(document.getElementById("deleteModal"));
                        if (deleteModalInstance) deleteModalInstance.hide();

                        new bootstrap.Modal(document.getElementById("deleteSuccessModal")).show();
                    } else {
                        alert("No se pudo eliminar el usuario.");
                    }
                });
            }

            const closeSuccessBtn = document.getElementById("closeSuccessBtn");
            if (closeSuccessBtn) {
                closeSuccessBtn.addEventListener("click", () => {
                    location.reload();
                });
            }

            // =========================
            // DETALLES (modal)
            // =========================
            async function loadDetails(id) {
                try {
                    const res = await fetch(`/Users/Details/${id}`);
                    if (!res.ok) throw new Error('Error fetching details');
                    const u = await res.json();

                    document.getElementById("det-name").innerText = (u.name ?? '') + ' ' + (u.lastName ?? '');
                    document.getElementById("det-domain").innerText = u.domainUser ?? '';
                    document.getElementById("det-team").innerText = u.teamName ?? '—';

                    new bootstrap.Modal(document.getElementById("detailsModal")).show();
                } catch (err) {
                    console.error('Error al cargar detalles:', err);
                }
            }

            const openEditFromDetails = document.getElementById("openEditFromDetails");
            if (openEditFromDetails) {
                openEditFromDetails.addEventListener("click", () => {
                    const detailsInstance = bootstrap.Modal.getInstance(document.getElementById("detailsModal"));
                    if (detailsInstance) detailsInstance.hide();
                    new bootstrap.Modal(document.getElementById("editModal")).show();
                });
            }

            // =========================
            // LIMPIAR FILTROS (DEFINITIVO)
            // =========================
            const clearFiltersBtnEl = document.getElementById('clearFiltersBtn');
            if (clearFiltersBtnEl) {
                clearFiltersBtnEl.addEventListener('click', (e) => {
                    e.preventDefault();

                    const form = document.getElementById('usersFiltersForm');
                    if (!form) {
                        window.location.href = window.location.pathname;
                        return;
                    }

                    form.querySelectorAll('input[type="text"], input[type="search"]').forEach(i => i.value = '');
                    form.querySelectorAll('select').forEach(s => s.value = '');

                    const pageField = form.querySelector('input[name="pageNumber"]');
                    if (pageField) pageField.value = 1;

                    form.submit();
                });
            }

        });
    </script>
}