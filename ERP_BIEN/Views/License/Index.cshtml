@model ERP_BIEN.ViewModels.LicenseIndexMvcViewModel

@{
    ViewData["Title"] = "Licenses";
}

<h2 class="mb-3">Licenses</h2>

<!-- FILTROS -->
<form method="get" asp-action="Index" asp-controller="License" class="card card-body mb-3">
    <div class="row g-2 align-items-end">

        <div class="col-auto">
            <label class="form-label">Búsqueda</label>
            <input type="text" name="Search" value="@Model.Search"
                   class="form-control" placeholder="Buscar código o producto" />
        </div>

        <div class="col-auto">
            <label class="form-label">Proveedor</label>
            <input type="text" name="SearchProveedor" value="@Model.SearchProveedor"
                   class="form-control" placeholder="Proveedor" />
        </div>

        <div class="col-auto">
            <label class="form-label">Producto</label>
            <input type="text" name="SearchProducto" value="@Model.SearchProducto"
                   class="form-control" placeholder="Producto" />
        </div>

        <div class="col-auto">
            <label class="form-label">Asignada</label>
            <select name="SearchAsignada" class="form-select">
                @if (string.IsNullOrWhiteSpace(Model.SearchAsignada))
                {
                    <option value="" selected>Todas</option>
                }
                else
                {
                    <option value="">Todas</option>
                }

                @if (Model.SearchAsignada == "true")
                {
                    <option value="true" selected>Sí</option>
                }
                else
                {
                    <option value="true">Sí</option>
                }

                @if (Model.SearchAsignada == "false")
                {
                    <option value="false" selected>No</option>
                }
                else
                {
                    <option value="false">No</option>
                }
            </select>
        </div>

        <div class="col-auto">
            <label class="form-label">Page size</label>
            <select name="PageSize" class="form-select">
                @if (Model.PageSize == 5)
                {
                    <option value="5" selected>5</option>
                }
                else
                {
                    <option value="5">5</option>
                }

                @if (Model.PageSize == 10)
                {
                    <option value="10" selected>10</option>
                }
                else
                {
                    <option value="10">10</option>
                }

                @if (Model.PageSize == 25)
                {
                    <option value="25" selected>25</option>
                }
                else
                {
                    <option value="25">25</option>
                }

                @if (Model.PageSize == 50)
                {
                    <option value="50" selected>50</option>
                }
                else
                {
                    <option value="50">50</option>
                }
            </select>
        </div>

        <div class="col-auto">
            <input type="hidden" name="PageNumber" value="1" />
            <button type="submit" class="btn btn-primary">Filtrar</button>
        </div>

        <div class="col-auto">
            <button type="button" class="btn btn-outline-secondary"
                    onclick="window.erpClearFiltersAndSubmit(this.closest('form'))">
                Limpiar filtros
            </button>
        </div>

        <div class="col-auto ms-auto">
            <button type="button" class="btn btn-success"
                    data-bs-toggle="modal" data-bs-target="#createEditModal">
                Crear licencia
            </button>
        </div>

    </div>
</form>

<!-- TABLA -->
<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Codigo</th>
                <th>Producto</th>
                <th>Proveedor</th>
                <th>Precio</th>
                <th>Caducidad</th>
                <th>Asignada</th>
                <th>Disponible</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Licenses.Any())
            {
                <tr>
                    <td colspan="8" class="text-center text-muted">No hay registros</td>
                </tr>
            }
            else
            {
                foreach (var item in Model.Licenses)
                {
                    <tr>
                        <td>@item.Code</td>
                        <td>@item.Producto</td>
                        <td>@item.Proveedor</td>
                        <td>@item.Price</td>
                        <td>@(item.Caducidad?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>@(item.Asignada ? "Sí" : "No")</td>
                        <td>@(item.Disponible ? "Sí" : "No")</td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-primary me-1 btn-details" data-id="@item.Id">
                                Detalles
                            </button>
                            <button type="button" class="btn btn-sm btn-warning me-1 btn-edit" data-id="@item.Id">
                                Editar
                            </button>
                            <button type="button" class="btn btn-sm btn-danger btn-delete"
                                    data-id="@item.Id"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- PAGINACIÓN -->
<nav aria-label="Page navigation" class="mt-3">
    <ul class="pagination justify-content-center">

        <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
            @if (Model.PageNumber > 1)
            {
                <a class="page-link"
                       asp-action="Index"
                       asp-controller="License"
                       asp-route-PageNumber="@(Model.PageNumber - 1)"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-Search="@Model.Search"
                       asp-route-SearchProveedor="@Model.SearchProveedor"
                       asp-route-SearchProducto="@Model.SearchProducto"
                       asp-route-SearchAsignada="@Model.SearchAsignada">
                    Anterior
                </a>
            }
            else
            {
                <span class="page-link">Anterior</span>
            }
        </li>

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-controller="License"
                       asp-route-PageNumber="@i"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-Search="@Model.Search"
                       asp-route-SearchProveedor="@Model.SearchProveedor"
                       asp-route-SearchProducto="@Model.SearchProducto"
                       asp-route-SearchAsignada="@Model.SearchAsignada">
                    @i
                </a>
            </li>
        }

        <li class="page-item @(Model.PageNumber == Model.TotalPages || Model.TotalPages == 0 ? "disabled" : "")">
            @if (Model.TotalPages > 0 && Model.PageNumber < Model.TotalPages)
            {
                <a class="page-link"
                       asp-action="Index"
                       asp-controller="License"
                       asp-route-PageNumber="@(Model.PageNumber + 1)"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-Search="@Model.Search"
                       asp-route-SearchProveedor="@Model.SearchProveedor"
                       asp-route-SearchProducto="@Model.SearchProducto"
                       asp-route-SearchAsignada="@Model.SearchAsignada">
                    Siguiente
                </a>
            }
            else
            {
                <span class="page-link">Siguiente</span>
            }
        </li>

    </ul>
</nav>

<!-- MODAL: DETALLES -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Detalles de la licencia</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detailsBody">
                <div class="text-center text-muted">Cargando...</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL: CREATE / EDIT -->
<div class="modal fade" id="createEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="createEditForm" method="post" asp-action="Create" asp-controller="License">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createEditTitle">Crear licencia</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="LicenseId" name="Id" value="0" />
                    <div class="mb-2">
                        <label class="form-label">Código</label>
                        <input class="form-control" id="Code" name="Code" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Producto</label>
                        <input class="form-control" id="Producto" name="Producto" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Proveedor</label>
                        <input class="form-control" id="Proveedor" name="Proveedor" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Precio</label>
                        <input class="form-control" id="Price" name="Price" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Caducidad</label>
                        <input type="date" class="form-control" id="Caducidad" name="Caducidad" />
                    </div>
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="Asignada" name="Asignada" />
                        <label class="form-check-label" for="Asignada">Asignada</label>
                    </div>
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="Disponible" name="Disponible" checked />
                        <label class="form-check-label" for="Disponible">Disponible</label>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Usuario asignado (Id)</label>
                        <input class="form-control" id="UserId" name="UserId" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" id="createEditSubmit">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL: ELIMINAR -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Eliminar licencia</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                ¿Seguro que deseas eliminar esta licencia?
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteId" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>
``