@model ERP_BIEN.Models.ViewModels.DevicesViewModel
@using ERP_BIEN.Common.Enums
@using ERP_BIEN.Models

@{
    ViewData["Title"] = "Gestión de Dispositivos";
}

<div class="page-header mb-3">
    <h2>Gestión de Dispositivos</h2>
</div>

<style>
    /* Acciones: mismo tamaño y alineación */
    .device-actions {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: .5rem;
        flex-wrap: nowrap;
    }
    .device-actions .btn { min-width: 92px; }
</style>

<!-- FILTROS AVANZADOS -->
<form method="get" class="card card-body mb-3">
    <div class="row g-2">
        <div class="col-md-2">
            <label class="form-label">Tipo</label>
            <select class="form-select" name="DeviceTypeFilter">
                <option value="">Todos</option>
                <option value="Computer" selected="@(Model.DeviceTypeFilter == "Computer")">Computer</option>
                <option value="Phone" selected="@(Model.DeviceTypeFilter == "Phone")">Phone</option>
                <option value="Screen" selected="@(Model.DeviceTypeFilter == "Screen")">Screen</option>
                <option value="DockStation" selected="@(Model.DeviceTypeFilter == "DockStation")">DockStation</option>
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">Estado</label>
            <select class="form-select" name="StatusFilter">
                <option value="">Todos</option>
                @foreach (StatusDevice s in Enum.GetValues(typeof(StatusDevice)))
                {
                    <option value="@s" selected="@(Model.StatusFilter == s)">
                        @s
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">Usuario</label>
            <select class="form-select" name="UserIdFilter">
                <option value="">Todos</option>
                @foreach (var u in Model.Users)
                {
                    <option value="@u.Id" selected="@(Model.UserIdFilter == u.Id)">
                        @u.Name @u.LastName
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">Hostname</label>
            <input class="form-control" name="HostnameFilter" value="@Model.HostnameFilter" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Modelo</label>
            <input class="form-control" name="ModelFilter" value="@Model.ModelFilter" />
        </div>

        <div class="col-md-2">
            <label class="form-label">SN</label>
            <input class="form-control" name="SNFilter" value="@Model.SNFilter" />
        </div>
    </div>

    <div class="row g-2 mt-2">
        <div class="col-md-3">
            <label class="form-label">Fabricación desde</label>
            <input type="date" class="form-control" name="ManufacturingFrom"
                   value="@(Model.ManufacturingFrom?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Fabricación hasta</label>
            <input type="date" class="form-control" name="ManufacturingTo"
                   value="@(Model.ManufacturingTo?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Uso desde</label>
            <input type="date" class="form-control" name="UseFrom"
                   value="@(Model.UseFrom?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Uso hasta</label>
            <input type="date" class="form-control" name="UseTo"
                   value="@(Model.UseTo?.ToString("yyyy-MM-dd"))" />
        </div>
    </div>

    <div class="mt-3 d-flex justify-content-between">
        <button type="submit" class="btn btn-primary">Filtrar</button>
        <button type="button" class="btn btn-outline-secondary"
                onclick="window.erpClearFiltersAndSubmit(this.closest('form'))">
            Limpiar filtros
        </button>
    </div>
</form>

<div class="d-flex justify-content-end mb-2">
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
        + Crear Dispositivo
    </button>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Tipo</th>
            <th>Hostname</th>
            <th>Modelo</th>
            <th>SN</th>
            <th>Estado</th>
            <th>Usuario</th>
            <th>Fecha uso</th>
            <th style="width:160px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model.Devices)
        {
            var tipo = d switch
            {
                Computer => "Computer",
                Phone => "Phone",
                Screen => "Screen",
                DockStation => "DockStation",
                _ => "Device"
            };

            <tr>
                <td>@tipo</td>
                <td>@d.Hostname</td>
                <td>@d.Model</td>
                <td>@d.SN</td>
                <td>@d.Status</td>
                <td>@(d.User != null ? d.User.Name + " " + d.User.LastName : "")</td>
                <td>@(d.UseDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                <td>
                    <div class="device-actions">
                        <button type="button"
                                class="btn btn-sm btn-outline-primary btn-details"
                                data-id="@d.Id">
                            Detalles
                        </button>

                        <button type="button"
                                class="btn btn-sm btn-warning"
                                data-bs-toggle="modal"
                                data-bs-target="#editModal"
                                data-id="@d.Id"
                                data-hostname="@d.Hostname"
                                data-model="@d.Model"
                                data-sn="@d.SN"
                                data-number="@d.NumberOfDevice"
                                data-manufacturing="@(d.ManufacturingDate?.ToString("yyyy-MM-dd"))"
                                data-status="@d.Status"
                                data-comment="@d.Comment"
                                data-use="@(d.UseDate?.ToString("yyyy-MM-dd"))"
                                data-userid="@d.UserId">
                            Editar
                        </button>

                        <button type="button"
                                class="btn btn-sm btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal"
                                data-id="@d.Id"
                                data-name="@d.Hostname">
                            Eliminar
                        </button>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Devices.Any())
{
    <p class="text-muted mt-3">No se encontraron dispositivos.</p>
}

<!-- PAGINACIÓN -->
@{
    var current = Model.PageNumber;
    var total = Model.TotalPages;
    var dt = Model.DeviceTypeFilter;
    var st = Model.StatusFilter;
    var uid = Model.UserIdFilter;
    var hn = Model.HostnameFilter;
    var md = Model.ModelFilter;
    var sn = Model.SNFilter;
}

<nav aria-label="Page navigation" class="mt-3">
    <ul class="pagination justify-content-center">

        <li class="page-item @(current == 1 ? "disabled" : "")" aria-disabled="@(current == 1)">
            @if (current > 1)
            {
                <a class="page-link"
                       href="@Url.Action("Index", new { pageNumber = current - 1, DeviceTypeFilter = dt, StatusFilter = st, UserIdFilter = uid, HostnameFilter = hn, ModelFilter = md, SNFilter = sn })">
                    Anterior
                </a>
            }
            else
            {
                <span class="page-link">Anterior</span>
            }
        </li>

        @for (int i = 1; i <= total; i++)
        {
            var isActive = i == current;
            <li class="page-item @(isActive ? "active" : "")" @(isActive ? "aria-current=\"page\"" : "")>
                @if (isActive)
                {
                    <span class="page-link">@i</span>
                }
                else
                {
                    <a class="page-link"
                           href="@Url.Action("Index", new { pageNumber = i, DeviceTypeFilter = dt, StatusFilter = st, UserIdFilter = uid, HostnameFilter = hn, ModelFilter = md, SNFilter = sn })">
                        @i
                    </a>
                }
            </li>
        }

        <li class="page-item @(current >= total || total == 0 ? "disabled" : "")" aria-disabled="@(current >= total || total == 0)">
            @if (current < total)
            {
                <a class="page-link"
                       href="@Url.Action("Index", new { pageNumber = current + 1, DeviceTypeFilter = dt, StatusFilter = st, UserIdFilter = uid, HostnameFilter = hn, ModelFilter = md, SNFilter = sn })">
                    Siguiente
                </a>
            }
            else
            {
                <span class="page-link">Siguiente</span>
            }
        </li>

    </ul>
</nav>


<!-- CREATE MODAL -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-action="Create">
                <div class="modal-header">
                    <h5 class="modal-title">Crear Dispositivo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <label class="form-label">Tipo de dispositivo</label>
                    <select class="form-select" name="DeviceType" required>
                        <option value="">-- Seleccionar --</option>
                        <option value="Computer">Computer</option>
                        <option value="Phone">Phone</option>
                        <option value="Screen">Screen</option>
                        <option value="DockStation">DockStation</option>
                    </select>

                    <label class="form-label mt-2">Hostname</label>
                    <input class="form-control" name="Hostname" required />

                    <label class="form-label mt-2">Modelo</label>
                    <input class="form-control" name="Model" />

                    <label class="form-label mt-2">SN</label>
                    <input class="form-control" name="SN" />

                    <label class="form-label mt-2">Número de dispositivo</label>
                    <input type="number" class="form-control" name="NumberOfDevice" value="1" />

                    <label class="form-label mt-2">Fecha fabricación</label>
                    <input type="date" class="form-control" name="ManufacturingDate" />

                    <label class="form-label mt-2">Estado</label>
                    <select class="form-select" name="Status">
                        @foreach (StatusDevice s in Enum.GetValues(typeof(StatusDevice)))
                        {
                            <option value="@s">@s</option>
                        }
                    </select>

                    <label class="form-label mt-2">Comentario</label>
                    <textarea class="form-control" name="Comment"></textarea>

                    <label class="form-label mt-2">Fecha uso</label>
                    <input type="date" class="form-control" name="UseDate" />

                    <label class="form-label mt-2">Usuario asignado</label>
                    <select class="form-select" name="UserId">
                        <option value="">-- Sin asignar --</option>
                        @foreach (var u in Model.Users)
                        {
                            <option value="@u.Id">@u.Name @u.LastName</option>
                        }
                    </select>

                    <!-- mantener filtros/paginación -->
                    <input type="hidden" name="pageNumber" value="@Model.PageNumber" />
                    <input type="hidden" name="deviceTypeFilter" value="@Model.DeviceTypeFilter" />
                    <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
                    <input type="hidden" name="userIdFilter" value="@Model.UserIdFilter" />
                    <input type="hidden" name="hostnameFilter" value="@Model.HostnameFilter" />
                    <input type="hidden" name="modelFilter" value="@Model.ModelFilter" />
                    <input type="hidden" name="snFilter" value="@Model.SNFilter" />
                    <input type="hidden" name="manufacturingFrom" value="@(Model.ManufacturingFrom?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="manufacturingTo" value="@(Model.ManufacturingTo?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="useFrom" value="@(Model.UseFrom?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="useTo" value="@(Model.UseTo?.ToString("yyyy-MM-dd"))" />
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Crear</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-action="Edit">
                <div class="modal-header">
                    <h5 class="modal-title">Editar Dispositivo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="edit-id" name="Id" />

                    <label class="form-label">Hostname</label>
                    <input class="form-control" id="edit-hostname" name="Hostname" required />

                    <label class="form-label mt-2">Modelo</label>
                    <input class="form-control" id="edit-model" name="Model" />

                    <label class="form-label mt-2">SN</label>
                    <input class="form-control" id="edit-sn" name="SN" />

                    <label class="form-label mt-2">Número de dispositivo</label>
                    <input type="number" class="form-control" id="edit-number" name="NumberOfDevice" />

                    <label class="form-label mt-2">Fecha fabricación</label>
                    <input type="date" class="form-control" id="edit-manufacturing" name="ManufacturingDate" />

                    <label class="form-label mt-2">Estado</label>
                    <select class="form-select" id="edit-status" name="Status">
                        @foreach (StatusDevice s in Enum.GetValues(typeof(StatusDevice)))
                        {
                            <option value="@s">@s</option>
                        }
                    </select>

                    <label class="form-label mt-2">Comentario</label>
                    <textarea class="form-control" id="edit-comment" name="Comment"></textarea>

                    <label class="form-label mt-2">Fecha uso</label>
                    <input type="date" class="form-control" id="edit-use" name="UseDate" />

                    <label class="form-label mt-2">Usuario asignado</label>
                    <select class="form-select" id="edit-userid" name="UserId">
                        <option value="">-- Sin asignar --</option>
                        @foreach (var u in Model.Users)
                        {
                            <option value="@u.Id">@u.Name @u.LastName</option>
                        }
                    </select>

                    <!-- mantener filtros/paginación -->
                    <input type="hidden" name="pageNumber" value="@Model.PageNumber" />
                    <input type="hidden" name="deviceTypeFilter" value="@Model.DeviceTypeFilter" />
                    <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
                    <input type="hidden" name="userIdFilter" value="@Model.UserIdFilter" />
                    <input type="hidden" name="hostnameFilter" value="@Model.HostnameFilter" />
                    <input type="hidden" name="modelFilter" value="@Model.ModelFilter" />
                    <input type="hidden" name="snFilter" value="@Model.SNFilter" />
                    <input type="hidden" name="manufacturingFrom" value="@(Model.ManufacturingFrom?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="manufacturingTo" value="@(Model.ManufacturingTo?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="useFrom" value="@(Model.UseFrom?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="useTo" value="@(Model.UseTo?.ToString("yyyy-MM-dd"))" />
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-action="Delete">
                <div class="modal-header">
                    <h5 class="modal-title">Eliminar Dispositivo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="delete-id" name="Id" />
                    <p>¿Seguro que deseas eliminar el dispositivo <strong id="delete-name"></strong>?</p>

                    <!-- mantener filtros/paginación -->
                    <input type="hidden" name="pageNumber" value="@Model.PageNumber" />
                    <input type="hidden" name="deviceTypeFilter" value="@Model.DeviceTypeFilter" />
                    <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
                    <input type="hidden" name="userIdFilter" value="@Model.UserIdFilter" />
                    <input type="hidden" name="hostnameFilter" value="@Model.HostnameFilter" />
                    <input type="hidden" name="modelFilter" value="@Model.ModelFilter" />
                    <input type="hidden" name="snFilter" value="@Model.SNFilter" />
                    <input type="hidden" name="manufacturingFrom" value="@(Model.ManufacturingFrom?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="manufacturingTo" value="@(Model.ManufacturingTo?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="useFrom" value="@(Model.UseFrom?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="useTo" value="@(Model.UseTo?.ToString("yyyy-MM-dd"))" />
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // DETAILS modal (carga partial HTML)
        const detailsModalEl = document.getElementById('detailsModal');
        const detailsBodyEl = document.getElementById('detailsBody');
        const detailsModal = detailsModalEl ? new bootstrap.Modal(detailsModalEl) : null;

        document.querySelectorAll('.btn-details').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                e.stopPropagation();
                const id = btn.dataset.id;
                if (!id || !detailsBodyEl || !detailsModal) return;
                detailsBodyEl.innerHTML = '<div class="text-center text-muted py-3">Cargando...</div>';
                detailsModal.show();
                try {
                    const res = await fetch(`/Devices/Details/${id}`);
                    if (!res.ok) throw new Error('Error');
                    detailsBodyEl.innerHTML = await res.text();
                } catch {
                    detailsBodyEl.innerHTML = '<div class="text-danger text-center py-3">Error al cargar detalles</div>';
                }
            });
        });

        var editModal = document.getElementById('editModal');
        editModal.addEventListener('show.bs.modal', function (event) {
            var b = event.relatedTarget;

            document.getElementById('edit-id').value = b.getAttribute('data-id');
            document.getElementById('edit-hostname').value = b.getAttribute('data-hostname');
            document.getElementById('edit-model').value = b.getAttribute('data-model');
            document.getElementById('edit-sn').value = b.getAttribute('data-sn');
            document.getElementById('edit-number').value = b.getAttribute('data-number');
            document.getElementById('edit-manufacturing').value = b.getAttribute('data-manufacturing');
            document.getElementById('edit-status').value = b.getAttribute('data-status');
            document.getElementById('edit-comment').value = b.getAttribute('data-comment');
            document.getElementById('edit-use').value = b.getAttribute('data-use');
            document.getElementById('edit-userid').value = b.getAttribute('data-userid');
        });

        var deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var b = event.relatedTarget;
            document.getElementById('delete-id').value = b.getAttribute('data-id');
            document.getElementById('delete-name').innerText = b.getAttribute('data-name');
        });
    </script>
}

<!-- DETAILS MODAL -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Detalles del Dispositivo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body" id="detailsBody">
                <div class="text-center text-muted py-3">Cargando...</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
