@model ERP_BIEN.ViewModels.AuditIndexViewModel

@{
    ViewData["Title"] = "Auditoría";

    var qUser = Context.Request.Query["user"];
    var qAction = Context.Request.Query["action"];
    var qEntity = Context.Request.Query["entity"];
    var qFrom = Context.Request.Query["from"];
    var qTo = Context.Request.Query["to"];
}

<h2 class="mb-3">Auditoría</h2>

<!-- ========================= -->
<!-- FILTROS -->
<!-- ========================= -->
<form method="get" class="card card-body mb-3">
    <div class="row g-3">

        <div class="col-md-3">
            <label class="form-label">Usuario</label>
            <input name="user" class="form-control" value="@qUser" placeholder="Nombre de usuario" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Acción</label>
            <select name="action" class="form-select">
                <option value="">Todas</option>

                @if (qAction == "Create")
                {
                    <option value="Create" selected>Create</option>
                }
                else
                {
                    <option value="Create">Create</option>
                }

                @if (qAction == "Edit")
                {
                    <option value="Edit" selected>Edit</option>
                }
                else
                {
                    <option value="Edit">Edit</option>
                }

                @if (qAction == "Delete")
                {
                    <option value="Delete" selected>Delete</option>
                }
                else
                {
                    <option value="Delete">Delete</option>
                }

                @if (qAction == "Assign")
                {
                    <option value="Assign" selected>Assign</option>
                }
                else
                {
                    <option value="Assign">Assign</option>
                }

                @if (qAction == "Remove")
                {
                    <option value="Remove" selected>Remove</option>
                }
                else
                {
                    <option value="Remove">Remove</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">Entidad</label>
            <select name="entity" class="form-select">
                <option value="">Todas</option>

                @if (qEntity == "Employee")
                {
                    <option value="Employee" selected>Employee</option>
                }
                else
                {
                    <option value="Employee">Employee</option>
                }

                @if (qEntity == "Device")
                {
                    <option value="Device" selected>Device</option>
                }
                else
                {
                    <option value="Device">Device</option>
                }

                @if (qEntity == "License")
                {
                    <option value="License" selected>License</option>
                }
                else
                {
                    <option value="License">License</option>
                }

                @if (qEntity == "Role")
                {
                    <option value="Role" selected>Role</option>
                }
                else
                {
                    <option value="Role">Role</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">Desde</label>
            <input type="date" name="from" class="form-control" value="@qFrom" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Hasta</label>
            <input type="date" name="to" class="form-control" value="@qTo" />
        </div>

        <div class="col-md-1 d-flex align-items-end">
            <button class="btn btn-primary w-100">Filtrar</button>
        </div>

    </div>
</form>

<!-- ========================= -->
<!-- TABLA -->
<!-- ========================= -->
<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Fecha</th>
                <th>Usuario</th>
                <th>Acción</th>
                <th>Entidad</th>
                <th>Id</th>
                <th>Detalles</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Logs.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-3">
                        No hay registros de auditoría
                    </td>
                </tr>
            }
            else
            {
                foreach (var log in Model.Logs)
                {
                    <tr>
                        <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@log.UserName</td>
                        <td>@log.Action</td>
                        <td>@log.Entity</td>
                        <td>@log.EntityId</td>
                        <td>@log.Details</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- ========================= -->
<!-- PAGINACIÓN -->
<!-- ========================= -->
@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-3">
        <ul class="pagination justify-content-center">

            <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                <a class="page-link"
                   href="@Url.Action("Index", new {
                       page = Model.Page - 1,
                       pageSize = Model.PageSize,
                       user = qUser,
                       action = qAction,
                       entity = qEntity,
                       from = qFrom,
                       to = qTo
                   })">
                    Anterior
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link"
                       href="@Url.Action("Index", new {
                           page = i,
                           pageSize = Model.PageSize,
                           user = qUser,
                           action = qAction,
                           entity = qEntity,
                           from = qFrom,
                           to = qTo
                       })">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   href="@Url.Action("Index", new {
                       page = Model.Page + 1,
                       pageSize = Model.PageSize,
                       user = qUser,
                       action = qAction,
                       entity = qEntity,
                       from = qFrom,
                       to = qTo
                   })">
                    Siguiente
                </a>
            </li>

        </ul>
    </nav>
}