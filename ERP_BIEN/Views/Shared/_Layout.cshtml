<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SONOVISION</title>

    <!-- Bootstrap + tus estilos -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ERP_BIEN.styles.css" asp-append-version="true" />

    <!-- Estilos del dashboard y layout corporativo -->
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>

<body>

    <div class="layout-container">

        <!-- SIDEBAR -->
        <aside class="sidebar" id="erpSidebar">
            <div class="sidebar-logo">
                <img src="~/img/LogoSonovisionAzul.png" alt="SONOVISION" class="logo-img" />
            </div>

            <nav class="sidebar-menu">
                <div class="sidebar-section">
                    <div class="sidebar-section-title">General</div>
                    <a class="sidebar-link" href="/Dashboard"><span class="sidebar-ico">▦</span><span class="sidebar-text">Dashboard</span></a>
                </div>

                <div class="sidebar-sep"></div>

                <div class="sidebar-section">
                    <div class="sidebar-section-title">Gestión</div>
                    <a class="sidebar-link" href="/Users"><span class="sidebar-ico">👤</span><span class="sidebar-text">Usuarios</span></a>
                    <a class="sidebar-link" href="/Roles"><span class="sidebar-ico">🛡</span><span class="sidebar-text">Roles</span></a>
                    <a class="sidebar-link" href="/Devices"><span class="sidebar-ico">💻</span><span class="sidebar-text">Dispositivos</span></a>
                    <a class="sidebar-link" href="/Licenses"><span class="sidebar-ico">🔑</span><span class="sidebar-text">Licencias</span></a>
                    <a class="sidebar-link" href="/Employees"><span class="sidebar-ico">🏢</span><span class="sidebar-text">Empleados</span></a>
                </div>

                <div class="sidebar-sep"></div>

                <div class="sidebar-section">
                    <div class="sidebar-section-title">Acciones</div>
                    <a class="sidebar-link" href="/Audit"><span class="sidebar-ico">🧾</span><span class="sidebar-text">Auditoría</span></a>
                    <a class="sidebar-link" href="/Import"><span class="sidebar-ico">⭳</span><span class="sidebar-text">Importación</span></a>
                </div>

                <div class="sidebar-sep"></div>

                <div class="sidebar-section">
                    <div class="sidebar-section-title">Mi área</div>
                    <a class="sidebar-link" href="/MyDevices"><span class="sidebar-ico">📦</span><span class="sidebar-text">Mis dispositivos</span></a>
                    <a class="sidebar-link" href="/MyLicenses"><span class="sidebar-ico">🗝</span><span class="sidebar-text">Mis licencias</span></a>
                    <a class="sidebar-link" href="/Team"><span class="sidebar-ico">👥</span><span class="sidebar-text">Equipo a tu cargo</span></a>
                    <a class="sidebar-link" href="/MyData"><span class="sidebar-ico">ℹ</span><span class="sidebar-text">Mis Datos</span></a>
                </div>
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="main-content">

            <!-- TOPBAR -->
            <header class="topbar">
                <button type="button" class="sidebar-toggle" id="erpSidebarToggle" aria-label="Abrir/cerrar menú">
                    ☰
                </button>
                <div class="topbar-user">
                    <span class="user-icon">M</span>
                    <span class="user-name">@User.Identity?.Name</span>
                </div>

                <a class="logout-btn" href="/Logout">Cerrar sesión</a>
            </header>

            <!-- PAGE CONTENT -->
            <section class="page-content">
                @RenderBody()
            </section>

        </main>

    </div>

    <!-- Scripts originales -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Utilidad corporativa: limpiar filtros y resetear a página 1 (GET)
        window.erpClearFiltersAndSubmit = function (form) {
            if (!form) return;

            // inputs texto/búsqueda/date/number
            form.querySelectorAll('input').forEach(i => {
                const t = (i.type || '').toLowerCase();
                const n = (i.name || '');
                if (/__RequestVerificationToken/i.test(n)) return;
                if (t === 'text' || t === 'search' || t === 'date' || t === 'number') i.value = '';
            });

            // selects => primera opción
            form.querySelectorAll('select').forEach(s => s.selectedIndex = 0);

            // reset pageNumber/PageNumber a 1 si existe (cualquier casing)
            const page = form.querySelector('input[name="pageNumber"], input[name="PageNumber"], input[name="pagenumber"]');
            if (page) page.value = 1;

            form.submit();
        };

        // Sidebar toggle (sin cambiar rutas ni controladores)
        (function () {
            const btn = document.getElementById('erpSidebarToggle');
            const root = document.documentElement;
            if (!btn) return;

            btn.addEventListener('click', () => {
                root.classList.toggle('sidebar-collapsed');
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
