@model ERP_BIEN.Models.ViewModels.RoleIndexMvcViewModel

@{
    ViewData["Title"] = "Gestión de Roles";
}

<div class="page-header d-flex justify-content-between align-items-center mb-3">
    <h2>Gestión de Roles</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">+ Crear Rol</button>
</div>

<form method="get" asp-action="Index" asp-controller="Role" class="card card-body mb-3">
    <div class="row g-2 align-items-end">
    <div class="col-auto">
        <label class="form-label">Búsqueda</label>
        <input type="text" name="Search" value="@Model.Search" class="form-control" placeholder="Buscar código o nombre" />
    </div>
    <div class="col-auto">
        <label class="form-label">Page size</label>
        <select name="PageSize" class="form-select">
            <option value="5" @(Model.PageSize == 5 ? "selected" : "")>5</option>
            <option value="10" @(Model.PageSize == 10 ? "selected" : "")>10</option>
            <option value="25" @(Model.PageSize == 25 ? "selected" : "")>25</option>
            <option value="50" @(Model.PageSize == 50 ? "selected" : "")>50</option>
        </select>
    </div>
    <div class="col-auto">
        <input type="hidden" name="PageNumber" value="1" />
        <button type="submit" class="btn btn-primary">Filtrar</button>
    </div>
    <div class="col-auto">
        <button type="button" class="btn btn-outline-secondary"
                onclick="window.erpClearFiltersAndSubmit(this.closest('form'))">
            Limpiar filtros
        </button>
    </div>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th style="width:220px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Roles.Any())
        {
            <tr><td colspan="3" class="text-center text-muted">No se encontraron roles.</td></tr>
        }
        else
        {
            foreach (var role in Model.Roles)
            {
                <tr>
                    <td>@role.Code</td>
                    <td>@role.Name</td>
                    <td>
                        <button class="btn btn-sm btn-warning"
                                data-bs-toggle="modal"
                                data-bs-target="#editModal"
                                data-id="@role.Id"
                                data-code="@role.Code"
                                data-name="@role.Name">
                            Editar
                        </button>

                        <!-- Botón que abre el modal de eliminar -->
                        <button type="button"
                                class="btn btn-sm btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal"
                                data-id="@role.Id"
                                data-name="@role.Name">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<!-- PAGINACIÓN -->
<nav aria-label="Page navigation" class="mt-3">
    <ul class="pagination justify-content-center">
        <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
            @if (Model.PageNumber > 1)
            {
                <a class="page-link"
                   asp-action="Index"
                   asp-controller="Role"
                   asp-route-PageNumber="@(Model.PageNumber - 1)"
                   asp-route-PageSize="@Model.PageSize"
                   asp-route-Search="@Model.Search">Anterior</a>
            }
            else
            {
                <span class="page-link">Anterior</span>
            }
        </li>

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-controller="Role"
                   asp-route-PageNumber="@i"
                   asp-route-PageSize="@Model.PageSize"
                   asp-route-Search="@Model.Search">@i</a>
            </li>
        }

        <li class="page-item @(Model.PageNumber == Model.TotalPages || Model.TotalPages == 0 ? "disabled" : "")">
            @if (Model.TotalPages > 0 && Model.PageNumber < Model.TotalPages)
            {
                <a class="page-link"
                   asp-action="Index"
                   asp-controller="Role"
                   asp-route-PageNumber="@(Model.PageNumber + 1)"
                   asp-route-PageSize="@Model.PageSize"
                   asp-route-Search="@Model.Search">Siguiente</a>
            }
            else
            {
                <span class="page-link">Siguiente</span>
            }
        </li>
    </ul>
</nav>

<!-- CREATE MODAL -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="Create" asp-controller="Role" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Crear Rol</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <label>Código</label>
                    <input class="form-control" name="Code" required />

                    <label class="mt-2">Nombre</label>
                    <input class="form-control" name="Name" required />

                    <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                    <input type="hidden" name="PageSize" value="@Model.PageSize" />
                    <input type="hidden" name="Search" value="@Model.Search" />
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Crear</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="Edit" asp-controller="Role" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Editar Rol</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="edit-id" name="Id" />
                    <label>Código</label>
                    <input class="form-control" id="edit-code" name="Code" required />
                    <label class="mt-2">Nombre</label>
                    <input class="form-control" id="edit-name" name="Name" required />

                    <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                    <input type="hidden" name="PageSize" value="@Model.PageSize" />
                    <input type="hidden" name="Search" value="@Model.Search" />
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <!-- El formulario del modal envía al action Delete del controlador Role -->
            <form asp-action="Delete" asp-controller="Role" method="post" id="deleteForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Eliminar Rol</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="delete-id" name="id" />
                    <p>¿Seguro que deseas eliminar el rol <strong id="delete-name"></strong>?</p>

                    <!-- Mantener estado de paginación/filtro -->
                    <input type="hidden" id="delete-PageNumber" name="PageNumber" value="@Model.PageNumber" />
                    <input type="hidden" id="delete-PageSize" name="PageSize" value="@Model.PageSize" />
                    <input type="hidden" id="delete-Search" name="Search" value="@Model.Search" />
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // EDIT modal: rellenar campos
        var editModal = document.getElementById('editModal');
        editModal?.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('edit-id').value = button.getAttribute('data-id');
            document.getElementById('edit-code').value = button.getAttribute('data-code');
            document.getElementById('edit-name').value = button.getAttribute('data-name');
        });

        // DELETE modal: rellenar id y nombre
        var deleteModal = document.getElementById('deleteModal');
        deleteModal?.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-id');
            var name = button.getAttribute('data-name');

            document.getElementById('delete-id').value = id;
            document.getElementById('delete-name').innerText = name;

            // Asegurar que los campos de paginación/filtro se mantienen (si cambias la vista, actualiza estos selectores)
            document.getElementById('delete-PageNumber').value = "@Model.PageNumber";
            document.getElementById('delete-PageSize').value = "@Model.PageSize";
            document.getElementById('delete-Search').value = "@Model.Search";
        });

        // Prevención: si usas confirm adicional, puedes interceptar el submit del formulario
        // document.getElementById('deleteForm').addEventListener('submit', function(e) {
        //     // e.g. mostrar spinner, deshabilitar botón, etc.
        // });
    </script>
}
