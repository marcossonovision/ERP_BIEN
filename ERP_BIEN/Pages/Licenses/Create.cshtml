@page "/Licenses/Create"
@model ERP_BIEN.Pages.Licenses.CreateModel

<link rel="stylesheet" href="~/css/licenses.css" />

<div class="page-container">

    <h1 class="page-title">Crear Licencia</h1>

    <form method="post" class="create-form">

        <label>Producto</label>
        <input type="text" name="Product" class="input-text" required />

        <label>Clave</label>
        <input type="text" name="Key" class="input-text" required />

        <label>Asignado a</label>
        <input type="text" name="AssignedTo" class="input-text" />

        <label>Estado</label>
        <select name="Status" class="input-select">
            <option value="Disponible">Disponible</option>
            <option value="Activo">Activo</option>
            <option value="Expirada">Expirada</option>
        </select>

        <button type="submit" class="btn-add">Crear</button>
        <a href="/Licenses" class="btn-cancel">Cancelar</a>

    </form>

</div>
