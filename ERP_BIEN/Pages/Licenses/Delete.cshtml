@page "/Licenses/Delete"
@model ERP_BIEN.Pages.Licenses.DeleteModel

<link rel="stylesheet" href="~/css/licenses.css" />

<div class="page-container">

    <h1 class="page-title">Eliminar Licencia</h1>

    <div class="delete-box">
        <p class="delete-warning">¿Seguro que deseas eliminar esta licencia?</p>

        <table class="delete-table">
            <tr><th>Producto:</th><td>@Model.License.Product</td></tr>
            <tr><th>Clave:</th><td>@Model.License.Key</td></tr>
            <tr><th>Asignado a:</th><td>@Model.License.AssignedTo</td></tr>
            <tr><th>Estado:</th><td>@Model.License.Status</td></tr>
        </table>

        <form method="post">
            <button type="submit" class="btn-delete-confirm">Eliminar</button>
            <a href="/Licenses" class="btn-cancel">Cancelar</a>
        </form>
    </div>

</div>
