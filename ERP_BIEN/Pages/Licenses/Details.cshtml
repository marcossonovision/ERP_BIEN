@page "/Licenses/Details"
@model ERP_BIEN.Pages.Licenses.DetailsModel

<link rel="stylesheet" href="~/css/licenses.css" />

<div class="page-container">

    <h1 class="page-title">Detalles de la Licencia</h1>

    <div class="details-box">
        <table class="details-table">
            <tr><th>Producto:</th><td>@Model.License.Product</td></tr>
            <tr><th>Clave:</th><td>@Model.License.Key</td></tr>
            <tr><th>Asignado a:</th><td>@Model.License.AssignedTo</td></tr>
            <tr><th>Estado:</th><td>@Model.License.Status</td></tr>
        </table>

        <a href="/Licenses/Edit?id=@Model.License.Id" class="btn-edit">Editar</a>
        <a href="/Licenses" class="btn-back">Volver</a>
    </div>

</div>
