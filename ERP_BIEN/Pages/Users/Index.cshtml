@page "{pageNumber:int?}"
@model ERP_BIEN.Pages.Users.IndexModel

<h2 class="mb-4">Gestión de Usuarios</h2>

<style>
    .user-row button {
        pointer-events: auto !important;
        position: relative;
        z-index: 10;
    }

    .user-row {
        position: relative;
        z-index: 1;
        cursor: pointer;
    }
</style>

<!-- ========================= -->
<!-- FILTROS + CREAR USUARIO -->
<!-- ========================= -->
<form method="get" class="row g-3 p-3 mb-4 rounded" style="background:#f5f5f5; border:1px solid #ddd;">

    <div class="col-md-3">
        <label class="form-label fw-bold">🔍 Nombre</label>
        <input name="SearchName" value="@Model.SearchName" class="form-control" placeholder="Buscar por nombre..." />
    </div>

    <div class="col-md-3">
        <label class="form-label fw-bold">👤 Usuario</label>
        <input name="SearchDomain" value="@Model.SearchDomain" class="form-control" placeholder="Buscar por usuario..." />
    </div>

    <div class="col-md-3">
        <label class="form-label fw-bold">🏢 Equipo</label>
        <select name="SearchTeamId" class="form-control">
            <option value="">Todos</option>
            @foreach (var t in Model.TeamList)
            {
                <option value="@t.Value" selected="@(Model.SearchTeamId == t.Value)">
                    @t.Text
                </option>
            }
        </select>
    </div>

    <div class="col-md-3 d-flex align-items-end gap-2">
        <button class="btn btn-primary w-100">Buscar</button>
        <a asp-page="Index" class="btn btn-secondary w-100">Limpiar</a>
        <a asp-page-handler="ExportExcel" class="btn btn-success w-100">📊 Excel</a>
    </div>

    <!-- BOTÓN CREAR USUARIO DENTRO DEL CUADRO -->
    <div class="col-12 d-flex justify-content-end mt-2">
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
            + Crear Usuario
        </button>
    </div>

</form>

<!-- ========================= -->
<!-- TABLA -->
<!-- ========================= -->
<table class="table table-hover">
    <thead class="table-light">
        <tr>
            <th>Nombre</th>
            <th>Usuario</th>
            <th>Equipo</th>
            <th style="width:150px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model.Users)
        {
            <tr class="user-row" data-id="@u.Id">

                <td>@u.Name @u.LastName</td>
                <td>@u.DomainUser</td>
                <td>@u.Team?.Name</td>

                <td>
                    <button class="btn btn-sm btn-warning edit-btn" data-id="@u.Id">Editar</button>
                    <button class="btn btn-sm btn-danger delete-btn" data-id="@u.Id">Eliminar</button>
                </td>

            </tr>
        }
    </tbody>
</table>

<!-- ========================= -->
<!-- PAGINACIÓN -->
<!-- ========================= -->
<nav>
    <ul class="pagination">
        <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
            <a class="page-link"
               asp-route-pageNumber="@(Model.PageNumber - 1)"
               asp-route-SearchName="@Model.SearchName"
               asp-route-SearchDomain="@Model.SearchDomain"
               asp-route-SearchTeamId="@Model.SearchTeamId">Anterior</a>
        </li>

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                <a class="page-link"
                   asp-route-pageNumber="@i"
                   asp-route-SearchName="@Model.SearchName"
                   asp-route-SearchDomain="@Model.SearchDomain"
                   asp-route-SearchTeamId="@Model.SearchTeamId">@i</a>
            </li>
        }

        <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
            <a class="page-link"
               asp-route-pageNumber="@(Model.PageNumber + 1)"
               asp-route-SearchName="@Model.SearchName"
               asp-route-SearchDomain="@Model.SearchDomain"
               asp-route-SearchTeamId="@Model.SearchTeamId">Siguiente</a>
        </li>
    </ul>
</nav>

<!-- ========================= -->
<!-- MODAL: CREAR USUARIO -->
<!-- ========================= -->
<div class="modal fade" id="createModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <form method="post" asp-page-handler="Create">

                <div class="modal-header">
                    <h5 class="modal-title">Crear Usuario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <label>Nombre</label>
                    <input name="Name" class="form-control" required />

                    <label class="mt-3">Apellidos</label>
                    <input name="LastName" class="form-control" required />

                    <label class="mt-3">Usuario de Dominio</label>
                    <input name="DomainUser" class="form-control" required />

                    <label class="mt-3">Equipo</label>
                    <select name="TeamId" class="form-control">
                        <option value="">-- Sin equipo --</option>
                        @foreach (var t in Model.TeamList)
                        {
                            <option value="@t.Value">@t.Text</option>
                        }
                    </select>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-primary">Crear</button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- ========================= -->
<!-- MODAL: DETALLES -->
<!-- ========================= -->
<div class="modal fade" id="detailsModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Detalles del Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <p><strong>Nombre:</strong> <span id="det-name"></span></p>
                <p><strong>Usuario:</strong> <span id="det-domain"></span></p>
                <p><strong>Equipo:</strong> <span id="det-team"></span></p>

            </div>

            <div class="modal-footer">
                <button class="btn btn-warning" id="openEditFromDetails">Editar</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>

        </div>
    </div>
</div>

<!-- ========================= -->
<!-- MODAL: EDITAR -->
<!-- ========================= -->
<div class="modal fade" id="editModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <form method="post" asp-page-handler="Edit">

                <input type="hidden" name="Id" id="edit-id" />

                <div class="modal-header">
                    <h5 class="modal-title">Editar Usuario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <label>Nombre</label>
                    <input name="Name" id="edit-name" class="form-control" />

                    <label class="mt-3">Apellidos</label>
                    <input name="LastName" id="edit-lastname" class="form-control" />

                    <label class="mt-3">Usuario de Dominio</label>
                    <input name="DomainUser" id="edit-domain" class="form-control" />

                    <label class="mt-3">Equipo</label>
                    <select name="TeamId" id="edit-team" class="form-control">
                        @foreach (var t in Model.TeamList)
                        {
                            <option value="@t.Value">@t.Text</option>
                        }
                    </select>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-warning">Guardar Cambios</button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- ========================= -->
<!-- MODAL: ELIMINAR -->
<!-- ========================= -->
<div class="modal fade" id="deleteModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <form method="post" asp-page-handler="Delete">

                <input type="hidden" name="Id" id="delete-id" />

                <div class="modal-header">
                    <h5 class="modal-title">Eliminar Usuario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <p>¿Seguro que deseas eliminar este usuario?</p>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-danger">Eliminar</button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>

        // ============================
        // CLICK EN FILA → VER
        // ============================
        document.querySelectorAll(".user-row").forEach(row => {
            row.addEventListener("click", async (e) => {

                if (e.target.closest("button")) return;

                const id = row.dataset.id;
                await loadDetails(id);
            });
        });

        // ============================
        // BOTÓN EDITAR
        // ============================
        document.querySelectorAll(".edit-btn").forEach(btn => {
            btn.addEventListener("click", async (e) => {
                e.stopPropagation();

                const id = btn.dataset.id;
                const res = await fetch(`?handler=Details&id=${id}`);
                const u = await res.json();

                document.getElementById("edit-id").value = u.id;
                document.getElementById("edit-name").value = u.name;
                document.getElementById("edit-lastname").value = u.lastName;
                document.getElementById("edit-domain").value = u.domainUser;
                document.getElementById("edit-team").value = u.teamId;

                new bootstrap.Modal(document.getElementById("editModal")).show();
            });
        });

        // ============================
        // BOTÓN ELIMINAR
        // ============================
        document.querySelectorAll(".delete-btn").forEach(btn => {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                document.getElementById("delete-id").value = btn.dataset.id;
                new bootstrap.Modal(document.getElementById("deleteModal")).show();
            });
        });

        // ============================
        // CARGAR DETALLES
        // ============================
        async function loadDetails(id) {
            const res = await fetch(`?handler=Details&id=${id}`);
            const u = await res.json();

            document.getElementById("det-name").innerText = u.name + " " + u.lastName;
            document.getElementById("det-domain").innerText = u.domainUser;
            document.getElementById("det-team").innerText = u.teamName ?? "—";

            new bootstrap.Modal(document.getElementById("detailsModal")).show();
        }

        // ============================
        // DESDE DETALLES → EDITAR
        // ============================
        document.getElementById("openEditFromDetails").addEventListener("click", () => {
            const detailsModal = bootstrap.Modal.getInstance(document.getElementById("detailsModal"));
            detailsModal.hide();

            new bootstrap.Modal(document.getElementById("editModal")).show();
        });

    </script>
}
