@page "/Users"
@model ERP_BIEN.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Usuarios";
}

<link rel="stylesheet" href="~/css/users.css" />

<h1 class="users-title">Usuarios</h1>

<div class="users-filters">
    <form method="get" class="filters-form">

        <input type="text" name="Search" value="@Model.Search"
               placeholder="Buscar por nombre, DNI, email…" class="search-input" />

        <select name="RoleFilter" class="filter-select">
            <option value="">Rol</option>
            @foreach (var role in Model.AllRoles)
            {
                <option value="@role.Name" selected="@(Model.RoleFilter == role.Name)">
                    @role.Name
                </option>
            }
        </select>

        <select name="StatusFilter" class="filter-select">
            <option value="">Estado</option>
            <option value="Activo" selected="@(Model.StatusFilter == "Activo")">Activo</option>
            <option value="Inactivo" selected="@(Model.StatusFilter == "Inactivo")">Inactivo</option>
        </select>

        <button type="submit" class="filter-btn">Filtrar</button>

        <a href="/Users/Create" class="create-btn">Crear Usuario</a>
    </form>
</div>

<table class="users-table">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Email Corporativo</th>
            <th>Roles Asignados</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model.Users)
        {
            var estado = Model.GetEstado(u);
            <tr>
                <td>@u.Name @u.LastName</td>
                <td>@u.PersonalInfo?.Email</td>
                <td>@string.Join(", ", u.UserRoles.Select(ur => ur.Role.Name))</td>
                <td>
                    <span class="estado @(estado == "Activo" ? "activo" : "inactivo")">
                        @estado
                    </span>
                </td>
                <td>
                    <a onclick="openUserModal(@u.Id)" class="btn-ver">Ver</a>
                    <a href="/Users/Delete?id=@u.Id" class="btn-eliminar">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="pagination">
    @if (Model.CurrentPage > 1)
    {
        <a href="?page=1&Search=@Model.Search&RoleFilter=@Model.RoleFilter&StatusFilter=@Model.StatusFilter" class="page-btn">««</a>
        <a href="?page=@(Model.CurrentPage - 1)&Search=@Model.Search&RoleFilter=@Model.RoleFilter&StatusFilter=@Model.StatusFilter" class="page-btn">«</a>
    }

    @for (int i = 1; i <= Model.TotalPages; i++)
    {
        <a href="?page=@i&Search=@Model.Search&RoleFilter=@Model.RoleFilter&StatusFilter=@Model.StatusFilter"
           class="page-number @(i == Model.CurrentPage ? "active" : "")">@i</a>
    }

    @if (Model.CurrentPage < Model.TotalPages)
    {
        <a href="?page=@(Model.CurrentPage + 1)&Search=@Model.Search&RoleFilter=@Model.RoleFilter&StatusFilter=@Model.StatusFilter" class="page-btn">»</a>
        <a href="?page=@Model.TotalPages&Search=@Model.Search&RoleFilter=@Model.RoleFilter&StatusFilter=@Model.StatusFilter" class="page-btn">»»</a>
    }
</div>


<!-- ============================
     MODAL DE DETALLES DE USUARIO
     ============================ -->
<div id="userModal" class="modal-overlay" style="display:none;">
    <div class="modal-content">

        <div class="modal-header">
            <h2 id="modalName"></h2>
            <button class="modal-close" onclick="closeModal()">✖</button>
        </div>

        <div class="modal-body">

            <div class="modal-row">
                <label>Nombre</label>
                <span id="modalFirstName"></span>
            </div>

            <div class="modal-row">
                <label>Apellidos</label>
                <span id="modalLastName"></span>
            </div>

            <div class="modal-row">
                <label>Email</label>
                <span id="modalEmail"></span>
            </div>

            <div class="modal-row">
                <label>Usuario de Dominio</label>
                <span id="modalDomain"></span>
            </div>

            <div class="modal-row">
                <label>Roles</label>
                <span id="modalRoles"></span>
            </div>

            <div class="modal-row">
                <label>Estado</label>
                <span id="modalStatus"></span>
            </div>

        </div>

        <div class="modal-footer">
            <a id="modalEditBtn" class="btn-edit">Editar</a>
            <button class="btn-cancel" onclick="closeModal()">Cerrar</button>
        </div>

    </div>
</div>


<script>
    async function openUserModal(id) {

        const response = await fetch(`/Users/Details?id=${id}&handler=Json`);
        const data = await response.json();

        if (data.error) {
            alert("No se pudo cargar el usuario");
            return;
        }

        document.getElementById("modalName").innerText = data.name + " " + data.lastName;
        document.getElementById("modalFirstName").innerText = data.name;
        document.getElementById("modalLastName").innerText = data.lastName;
        document.getElementById("modalEmail").innerText = data.email;
        document.getElementById("modalDomain").innerText = data.domainUser;
        document.getElementById("modalRoles").innerText = data.roles;
        document.getElementById("modalStatus").innerText = data.status;

        document.getElementById("modalEditBtn").href = `/Users/Edit?id=${data.id}`;

        document.getElementById("userModal").style.display = "flex";
    }

    function closeModal() {
        document.getElementById("userModal").style.display = "none";
    }
</script>
